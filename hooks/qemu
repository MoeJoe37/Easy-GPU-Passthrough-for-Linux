#!/usr/bin/env bash
set -euo pipefail

DOMAIN="${1:-}"
OP="${2:-}"
SUBOP="${3:-}"

# libvirt QEMU hook: once the guest reaches stopped/end, ask the helper to
# restore host ownership and then reboot as the final recovery step.
if [[ "$OP" == "stopped" && "$SUBOP" == "end" ]]; then
  if [[ -x /usr/local/bin/gpu-switcher-ctl ]]; then
    /usr/local/bin/gpu-switcher-ctl on-vm-stopped "$DOMAIN" || true
  fi
fi
